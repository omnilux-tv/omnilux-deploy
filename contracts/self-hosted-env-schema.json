{
  "schemaVersion": 1,
  "product": "omnilux-self-hosted-runtime",
  "platforms": ["docker", "truenas", "linux", "macos", "cli"],
  "scopes": [
    "compose-substitution",
    "runtime-env",
    "native-installer-input",
    "native-env-file",
    "cli-override",
    "updater-env",
    "env-template"
  ],
  "variables": [
    { "name": "PORT", "default": "4000", "scopes": ["compose-substitution", "runtime-env", "native-env-file", "env-template"], "platforms": ["docker", "linux", "macos"] },
    { "name": "NODE_ENV", "default": "production", "scopes": ["runtime-env", "native-env-file"], "platforms": ["docker", "truenas", "linux", "macos"] },
    { "name": "LIBRARY_ROOT", "default": "/mnt/media", "scopes": ["compose-substitution", "env-template"], "platforms": ["docker"] },
    { "name": "LOG_LEVEL", "default": "info", "scopes": ["compose-substitution", "runtime-env", "native-env-file", "env-template"], "platforms": ["docker", "linux", "macos"] },
    { "name": "COMPOSE_PROFILES", "default": "", "scopes": ["compose-substitution", "env-template"], "platforms": ["truenas"] },
    { "name": "TMDB_API_KEY", "default": "", "sensitive": true, "scopes": ["compose-substitution", "runtime-env", "native-env-file", "env-template"], "platforms": ["docker", "truenas", "linux", "macos"] },
    { "name": "SUPABASE_URL", "default": "https://api.omnilux.tv", "scopes": ["compose-substitution", "runtime-env", "env-template"], "platforms": ["docker", "truenas"] },
    { "name": "SUPABASE_ANON_KEY", "default": "", "sensitive": true, "scopes": ["compose-substitution", "runtime-env", "env-template"], "platforms": ["docker", "truenas"] },
    { "name": "GHCR_TOKEN", "default": "", "sensitive": true, "scopes": ["native-installer-input"], "platforms": ["linux"] },
    { "name": "NODE_MAJOR", "default": "22", "scopes": ["native-installer-input"], "platforms": ["linux", "macos"] },

    { "name": "OMNILUX_IMAGE", "default": "ghcr.io/omnilux-tv/omnilux:latest", "scopes": ["compose-substitution", "native-installer-input", "updater-env", "env-template"], "platforms": ["docker", "truenas", "linux"] },
    { "name": "OMNILUX_STORAGE_ROOT", "default": "/mnt/Storage/Applications/OmniLux", "scopes": ["compose-substitution", "env-template"], "platforms": ["truenas"] },
    { "name": "OMNILUX_MEDIA_ROOT", "default": "/mnt/Storage/data/data/media", "scopes": ["compose-substitution", "env-template"], "platforms": ["truenas"] },
    { "name": "OMNILUX_DOCKER_NETWORK", "default": "ix-omnilux_default", "scopes": ["compose-substitution", "env-template"], "platforms": ["truenas"] },
    { "name": "OMNILUX_DISABLE_BACKGROUND_RUNTIME", "default": "false", "scopes": ["compose-substitution", "runtime-env", "env-template"], "platforms": ["truenas"] },
    { "name": "OMNILUX_DB_PATH", "default": "/app/data/omnilux.db", "scopes": ["runtime-env", "native-env-file"], "platforms": ["docker", "truenas", "linux", "macos"] },
    { "name": "OMNILUX_PLUGINS_DIR", "default": "/app/plugins", "scopes": ["runtime-env", "native-installer-input", "native-env-file"], "platforms": ["docker", "truenas", "linux", "macos"] },
    { "name": "OMNILUX_LIBRARY_ROOT", "default": "/data", "scopes": ["runtime-env", "native-env-file"], "platforms": ["docker", "truenas", "linux", "macos"] },
    { "name": "OMNILUX_DOWNLOAD_PATH", "default": "/app/data/downloads", "scopes": ["runtime-env", "native-env-file"], "platforms": ["docker", "linux", "macos"] },
    { "name": "OMNILUX_DEPLOYMENT_PROFILE", "default": "self-hosted", "scopes": ["compose-substitution", "runtime-env", "native-env-file", "env-template"], "platforms": ["docker", "truenas", "linux", "macos"] },
    { "name": "OMNILUX_PRIMARY_DEPLOYMENT", "default": "docker-compose|truenas-custom-app|bare-metal-linux|bare-metal-macos", "scopes": ["compose-substitution", "runtime-env", "native-env-file", "env-template"], "platforms": ["docker", "truenas", "linux", "macos"] },
    { "name": "OMNILUX_PUBLIC_ORIGIN", "default": "", "scopes": ["compose-substitution", "runtime-env", "native-installer-input", "native-env-file", "env-template"], "platforms": ["docker", "truenas", "linux", "macos", "windows"] },
    { "name": "OMNILUX_ALLOWED_ORIGINS", "default": "", "scopes": ["compose-substitution", "runtime-env", "native-env-file", "env-template"], "platforms": ["docker", "truenas", "linux", "macos", "windows"] },
    { "name": "OMNILUX_CLOUD_APP_URL", "default": "https://app.omnilux.tv", "scopes": ["compose-substitution", "runtime-env", "native-env-file", "cli-override", "env-template"], "platforms": ["docker", "truenas", "linux", "macos", "windows", "cli"] },
    { "name": "OMNILUX_CLOUD_URL", "default": "https://api.omnilux.tv", "scopes": ["runtime-env", "native-env-file", "cli-override"], "platforms": ["linux", "macos", "cli"] },
    { "name": "OMNILUX_RELAY_URL", "default": "wss://relay.omnilux.tv/ws/server", "scopes": ["runtime-env", "native-env-file", "cli-override"], "platforms": ["linux", "macos", "cli"] },
    { "name": "OMNILUX_BROWSER_SOLVER", "default": "auto", "scopes": ["runtime-env", "native-env-file"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_CLOUD_METADATA_BROKER_TOKEN", "default": "", "sensitive": true, "scopes": ["compose-substitution", "runtime-env", "env-template"], "platforms": ["docker", "truenas"] },
    { "name": "OMNILUX_ENTITLEMENT_LEASE_PUBLIC_KEY_SPKI_B64URL", "default": "", "scopes": ["compose-substitution", "runtime-env", "native-env-file", "env-template"], "platforms": ["docker", "truenas", "linux", "macos"] },
    { "name": "OMNILUX_ALLOW_UNSIGNED_ENTITLEMENT_LEASES", "default": "false", "scopes": ["compose-substitution", "runtime-env", "native-env-file", "env-template"], "platforms": ["docker", "truenas", "linux", "macos"] },

    { "name": "OMNILUX_UPDATER_URL", "default": "", "scopes": ["compose-substitution", "runtime-env", "env-template"], "platforms": ["truenas"] },
    { "name": "OMNILUX_UPDATER_TOKEN", "default": "", "sensitive": true, "scopes": ["compose-substitution", "runtime-env", "updater-env", "env-template"], "platforms": ["truenas"] },
    { "name": "OMNILUX_REPO_DIR", "default": "/repo", "scopes": ["updater-env"], "platforms": ["truenas"] },
    { "name": "OMNILUX_HEALTH_URL", "default": "http://omnilux:4000/api/health", "scopes": ["compose-substitution", "updater-env", "env-template"], "platforms": ["truenas"] },
    { "name": "OMNILUX_HEALTH_TIMEOUT_MS", "default": "120000", "scopes": ["updater-env", "env-template"], "platforms": ["truenas"] },
    { "name": "OMNILUX_HEALTH_INTERVAL_MS", "default": "3000", "scopes": ["updater-env", "env-template"], "platforms": ["truenas"] },

    { "name": "OMNILUX_IMAGE_PLATFORM", "default": "detected", "scopes": ["native-installer-input"], "platforms": ["linux"] },
    { "name": "OMNILUX_APP_DIR", "default": "/opt/omnilux|~/Library/Application Support/OmniLux/runtime", "scopes": ["native-installer-input"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_CONFIG_DIR", "default": "/etc/omnilux|~/Library/Application Support/OmniLux", "scopes": ["native-installer-input", "cli-override"], "platforms": ["linux", "macos", "cli"] },
    { "name": "OMNILUX_DATA_DIR", "default": "/var/lib/omnilux|~/Library/Application Support/OmniLux/data", "scopes": ["native-installer-input", "native-env-file"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_MEDIA_DIR", "default": "/srv/media|~/Movies/OmniLux", "scopes": ["native-installer-input"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_USER", "default": "omnilux", "scopes": ["native-installer-input"], "platforms": ["linux"] },
    { "name": "OMNILUX_GROUP", "default": "omnilux", "scopes": ["native-installer-input"], "platforms": ["linux"] },
    { "name": "OMNILUX_PORT", "default": "4000", "scopes": ["native-installer-input"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_SERVICE_NAME", "default": "omnilux", "scopes": ["native-installer-input", "cli-override"], "platforms": ["linux", "cli"] },
    { "name": "OMNILUX_SERVICE_LABEL", "default": "tv.omnilux.server", "scopes": ["native-installer-input", "cli-override"], "platforms": ["macos", "cli"] },
    { "name": "OMNILUX_START_SERVICE", "default": "1", "scopes": ["native-installer-input"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_SKIP_DEPENDENCIES", "default": "0", "scopes": ["native-installer-input"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_SKIP_NODE_SETUP", "default": "0", "scopes": ["native-installer-input"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_SKIP_NODE_CHECK", "default": "0", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_CLI_URL", "default": "https://raw.githubusercontent.com/omnilux-tv/omnilux-deploy/main/scripts/omnilux", "scopes": ["native-installer-input"], "platforms": ["docker", "linux", "macos"] },
    { "name": "OMNILUX_CLI_PATH", "default": "/usr/local/bin/omnilux|~/.local/bin/omnilux", "scopes": ["native-installer-input"], "platforms": ["linux", "macos"] },
    { "name": "OMNILUX_REGISTRY_USERNAME", "default": "", "sensitive": true, "scopes": ["native-installer-input"], "platforms": ["linux"] },
    { "name": "OMNILUX_REGISTRY_PASSWORD", "default": "", "sensitive": true, "scopes": ["native-installer-input"], "platforms": ["linux"] },
    { "name": "OMNILUX_REGISTRY_TOKEN", "default": "", "sensitive": true, "scopes": ["native-installer-input"], "platforms": ["linux"] },
    { "name": "OMNILUX_ARTIFACT_URL", "default": "auto", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_ARTIFACT_FILE", "default": "", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_ARCH", "default": "detected", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_INSTALL_ROOT", "default": "", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_APPLICATIONS_DIR", "default": "/Applications", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_NODE_BIN", "default": "auto", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_MENU_BAR_LABEL", "default": "tv.omnilux.menubar", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_START_MENU_BAR", "default": "same as OMNILUX_START_SERVICE", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_ALLOW_ROOT", "default": "0", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_MACOS_APP_NAME", "default": "OmniLux.app", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_LAUNCH_AGENT_DIR", "default": "~/Library/LaunchAgents", "scopes": ["native-installer-input"], "platforms": ["macos"] },
    { "name": "OMNILUX_CLI_DIR", "default": "~/.local/bin", "scopes": ["native-installer-input"], "platforms": ["macos"] },

    { "name": "OMNILUX_RUNTIME_URL", "default": "http://127.0.0.1:$PORT", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_API_TOKEN", "default": "", "sensitive": true, "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_ENV_FILE", "default": "$OMNILUX_CONFIG_DIR/omnilux.env", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_INSTALL_METADATA_FILE", "default": "$OMNILUX_CONFIG_DIR/install.json", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_CONTAINER_NAME", "default": "omnilux", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_COMPOSE_SERVICE", "default": "omnilux", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_COMPOSE_FILE", "default": "", "scopes": ["cli-override", "updater-env"], "platforms": ["cli", "truenas"] },
    { "name": "OMNILUX_COMPOSE_PROJECT", "default": "", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_CLI_HTTP_TIMEOUT", "default": "5", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_CLI_HEALTH_ATTEMPTS", "default": "30", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_PLIST_FILE", "default": "~/Library/LaunchAgents/$OMNILUX_SERVICE_LABEL.plist", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_OUT_LOG", "default": "$OMNILUX_DATA_DIR/logs/omnilux.out.log", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_ERR_LOG", "default": "$OMNILUX_DATA_DIR/logs/omnilux.err.log", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_LINUX_INSTALLER_URL", "default": "official install-linux.sh", "scopes": ["cli-override"], "platforms": ["cli"] },
    { "name": "OMNILUX_MACOS_INSTALLER_URL", "default": "official install-macos.sh", "scopes": ["cli-override"], "platforms": ["cli"] }
  ]
}
