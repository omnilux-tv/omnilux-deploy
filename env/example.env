# Optional: copy to `.env` next to `docker-compose.truenas.yml` and pass with
#   docker compose --env-file .env -f docker-compose.truenas.yml up -d
# TrueNAS Custom Apps usually set the same keys in the UI instead of a file.
#
# Do not commit real secrets.

# Generic Docker install overrides.
# PORT=4000
# LIBRARY_ROOT=/mnt/media
# LOG_LEVEL=info

# OMNILUX_IMAGE=ghcr.io/omnilux-tv/omnilux:latest

# Host paths (override defaults in docker-compose.truenas.yml)
# OMNILUX_STORAGE_ROOT=/path/to/parent/for/data/plugins/repo
# OMNILUX_MEDIA_ROOT=/path/to/media/library

# OMNILUX_DOCKER_NETWORK=ix-omnilux_default

# Optional in-app updates. Enabling this profile starts the updater sidecar with
# Docker socket access, so keep it disabled unless you need web-triggered updates.
# COMPOSE_PROFILES=updater
# OMNILUX_UPDATER_URL=http://omnilux-updater:4050
# Required when COMPOSE_PROFILES includes updater. Leave unset to disable the
# updater control API even if the sidecar is running.
# OMNILUX_UPDATER_TOKEN=replace-with-a-long-random-token
# OMNILUX_HEALTH_URL=http://omnilux:4000/api/health
# OMNILUX_HEALTH_TIMEOUT_MS=120000
# OMNILUX_HEALTH_INTERVAL_MS=3000
# OMNILUX_PUBLIC_ORIGIN=
# OMNILUX_ALLOWED_ORIGINS=
# OMNILUX_CLOUD_APP_URL=https://app.omnilux.tv
# OMNILUX_DEPLOYMENT_PROFILE=self-hosted
# OMNILUX_PRIMARY_DEPLOYMENT=truenas-custom-app
# SUPABASE_URL=https://api.omnilux.tv
# SUPABASE_ANON_KEY=
# OMNILUX_CLOUD_METADATA_BROKER_TOKEN=
# OMNILUX_ENTITLEMENT_LEASE_PUBLIC_KEY_SPKI_B64URL=
# OMNILUX_ALLOW_UNSIGNED_ENTITLEMENT_LEASES=false
# OMNILUX_DISABLE_BACKGROUND_RUNTIME=false
# TMDB_API_KEY=
