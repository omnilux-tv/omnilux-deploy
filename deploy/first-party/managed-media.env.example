OMNILUX_IMAGE=ghcr.io/omnilux-tv/omnilux:latest

SUPABASE_URL=https://api.omnilux.tv
SUPABASE_ANON_KEY=
TMDB_API_KEY=

OMNILUX_DEPLOYMENT_PROFILE=managed-media
OMNILUX_CONTAINER_NAME=omnilux-media
OMNILUX_BIND_PORT=4000
OMNILUX_PUBLIC_ORIGIN=https://media.omnilux.tv
OMNILUX_CLOUD_APP_URL=https://app.omnilux.tv
OMNILUX_ALLOWED_ORIGINS=https://app.omnilux.tv,https://media.omnilux.tv

OMNILUX_DATA_ROOT=/srv/omnilux/media/data
OMNILUX_LIBRARY_ROOT=/srv/omnilux/media/library
