OMNILUX_IMAGE=ghcr.io/omnilux-tv/omnilux:latest

SUPABASE_URL=https://api.omnilux.tv
SUPABASE_ANON_KEY=
TMDB_API_KEY=

OMNILUX_DEPLOYMENT_PROFILE=ops
OMNILUX_CONTAINER_NAME=omnilux-ops
OMNILUX_BIND_PORT=4000
OMNILUX_PUBLIC_ORIGIN=https://ops.omnilux.tv
OMNILUX_CLOUD_APP_URL=https://app.omnilux.tv
OMNILUX_ALLOWED_ORIGINS=https://app.omnilux.tv,https://ops.omnilux.tv

OMNILUX_DATA_ROOT=/srv/omnilux/ops/data
OMNILUX_LIBRARY_ROOT=/srv/omnilux/ops/library
